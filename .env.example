# Posthook (required)
POSTHOOK_API_KEY=phk_...
POSTHOOK_SIGNING_KEY=phs_...

# Database (required)
# Local dev: docker compose up -d db
DATABASE_URL=postgres://postgres:postgres@localhost:5432/approval_queue

# OpenAI (optional — falls back to mock AI if not set)
OPENAI_API_KEY=sk-...

# Timing (optional — defaults shown)
REMINDER_DELAY=1h
EXPIRATION_DELAY=24h
